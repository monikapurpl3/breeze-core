# Breeze Core service configuration (read by the systemd unit / OpenRC init).
#
# BREEZE_HOST: the address to bind.
#   - For direct LAN use, set this machine's LAN IP (e.g. 192.168.1.10).
#   - Keep 127.0.0.1 if a reverse proxy (nginx/Apache/Caddy) fronts it.
#   - Never use 0.0.0.0 — see HARDENING.md.
BREEZE_HOST=127.0.0.1
BREEZE_PORT=8420

# Extra args for `breeze-core serve` (e.g. --behind-proxy when a local
# reverse proxy terminates TLS and forwards the client IP):
BREEZE_OPTS=
